  }
  @media (max-width: 560px){
    .cert-grid{ grid-template-columns:1fr; }
    .wrap{ padding:0 20px; }
    .hero{ padding:70px 0 48px; }
  }
 
  @media (prefers-reduced-motion: reduce){
    html{ scroll-behavior:auto; }
    .ecg-divider path{ animation:none; stroke-dashoffset:0; }
  }
</style>
