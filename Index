    position:relative;
    overflow:hidden;
    margin-bottom:18px;
  }
  .id-card .avatar .mono{
    font-family:'Fraunces', serif;
    font-size:4.2rem;
    color:rgba(247,249,245,0.92);
    font-weight:600;
    letter-spacing:0.02em;
    z-index:2;
  }
  .id-card .avatar svg.ecg{
    position:absolute; bottom:14%; left:0; width:140%;
  }
  .id-row{
    display:flex; justify-content:space-between;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.78rem;
    padding:9px 0;
    border-top:1px dashed var(--line);
    color:var(--muted);
  }
  .id-row span:last-child{ color:var(--ink); font-weight:500; }
 
  /* full width ecg divider */
  .ecg-divider{
    width:100%; height:46px; display:block; margin:0 auto;
    overflow:hidden;
  }
  .ecg-divider path{
    fill:none; stroke:var(--pulse); stroke-width:2;
    stroke-linecap:round; stroke-linejoin:round;
    stroke-dasharray: 1400;
    stroke-dashoffset: 1400;
    animation: draw 3.2s ease-out forwards;
  }
  @keyframes draw{ to{ stroke-dashoffset:0; } }
 
  /* ---------- SECTION GENERIC ---------- */
  section{ padding:76px 0; }
  section.alt{ background:var(--paper-raise); border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
  .section-head{ margin-bottom:44px; max-width:60ch; }
  .section-head h2{ font-size:clamp(1.7rem, 3vw, 2.3rem); margin-top:10px; }
 
  /* ---------- ABOUT ---------- */
  .about-grid{
    display:grid; grid-template-columns: 1fr 1fr; gap:48px;
  }
  .about-grid p{ color:var(--muted); font-size:1rem; }
  .about-grid p + p{ margin-top:16px; }
  .pull{
    font-family:'Fraunces', serif;
    font-style:italic;
    font-size:1.3rem;
    line-height:1.4;
    color:var(--ink);
    border-left:2px solid var(--pulse);
    padding-left:20px;
  }
 
  /* ---------- TIMELINE ---------- */
  .timeline{
    position:relative;
    margin-top:8px;
  }
  .timeline::before{
    content:"";
    position:absolute; left:98px; top:6px; bottom:6px; width:1px;
    background:var(--line);
  }
  .t-row{
    display:grid;
    grid-template-columns: 98px 24px 1fr;
    gap:0;
    position:relative;
  }
  .t-date{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.76rem;
    color:var(--sage);
    padding-top:26px;
    text-align:right;
    padding-right:20px;
  }
  .t-dot-col{ display:flex; justify-content:center; }
  .t-dot{
    width:9px; height:9px; border-radius:50%;
    background:var(--paper); border:2px solid var(--pulse);
    margin-top:29px;
  }
  .t-content{ padding:20px 0 34px 24px; }
  .t-content h3{ font-size:1.08rem; font-weight:600; }
  .t-content .org{
    font-size:0.86rem; color:var(--sage); margin-top:2px; font-weight:500;
  }
  .t-content p{ color:var(--muted); font-size:0.92rem; margin:8px 0 0; max-width:60ch; }
  .t-tag{
    display:inline-block; margin-top:10px;
    font-family:'IBM Plex Mono', monospace; font-size:0.68rem;
    letter-spacing:0.06em; text-transform:uppercase;
    background:var(--sage-soft); color:var(--sage);
    padding:3px 9px; border-radius:99px;
  }
 
  /* ---------- CERTS ---------- */
  .cert-grid{
    display:grid;
    grid-template-columns: repeat(3, 1fr);
    gap:1px;
    background:var(--line);
    border:1px solid var(--line);
  }
  .cert{
    background:var(--paper);
    padding:26px 24px;
    display:flex; flex-direction:column; gap:10px;
  }
  .cert .num{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem; color:var(--pulse);
  }
  .cert h3{ font-size:1rem; font-weight:600; line-height:1.3; }
  .cert p{ margin:0; font-size:0.85rem; color:var(--muted); }
  .cert .date{
    margin-top:auto;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem; color:var(--muted);
    padding-top:10px; border-top:1px dashed var(--line);
  }
 
  /* ---------- SKILLS ---------- */
  .skills-grid{
    display:grid; grid-template-columns: 1.1fr 0.9fr; gap:56px;
  }
  .skill-block h3{
    font-size:1rem; text-transform:uppercase; letter-spacing:0.08em;
    font-family:'IBM Plex Mono', monospace; font-weight:500; color:var(--sage);
    margin-bottom:16px;
  }
  .chip-list{ display:flex; flex-wrap:wrap; gap:10px; margin-bottom:34px; }
  .chip{
    border:1px solid var(--line); background:var(--paper-raise);
    padding:8px 14px; border-radius:99px; font-size:0.86rem;
  }
  .lang-row{
    display:grid; grid-template-columns: 110px 1fr 70px;
    align-items:center; gap:14px; margin-bottom:16px;
    font-size:0.9rem;
  }
  .lang-name{ font-weight:500; }
  .meter{
    height:6px; background:var(--sage-soft); border-radius:99px; overflow:hidden;
  }
  .meter i{
    display:block; height:100%; background:var(--pulse); border-radius:99px;
  }
  .lang-level{ font-family:'IBM Plex Mono', monospace; font-size:0.74rem; color:var(--muted); text-align:right; }
 
  /* ---------- CONTACT ---------- */
  .contact-card{
    background:var(--ink); color:var(--paper-raise);
    border-radius:8px; padding:52px;
    display:grid; grid-template-columns: 1.2fr 1fr; gap:40px; align-items:center;
