  .contact-card h2{ color:var(--paper-raise); font-size:clamp(1.7rem,3vw,2.2rem); }
  .contact-card p{ color:#B9C4BE; margin-top:14px; max-width:44ch; }
  .contact-list{ list-style:none; margin:0; padding:0; }
  .contact-list li{
    padding:14px 0; border-top:1px solid rgba(247,249,245,0.14);
    display:flex; justify-content:space-between; font-size:0.92rem;
  }
  .contact-list li:last-child{ border-bottom:1px solid rgba(247,249,245,0.14); }
  .contact-list span.k{ color:#8AA093; font-family:'IBM Plex Mono', monospace; font-size:0.76rem; text-transform:uppercase; letter-spacing:0.06em; }
  .contact-list a{ text-decoration:none; color:var(--paper-raise); }
  .contact-list a:hover{ color:var(--pulse-soft); }
 
  footer{
    padding:30px 0 50px; text-align:center;
    font-family:'IBM Plex Mono', monospace; font-size:0.75rem; color:var(--muted);
  }
 
  @media (max-width: 860px){
    .nav-links{ display:none; }
    .hero-grid{ grid-template-columns:1fr; }
    .id-card{ max-width:320px; margin:0 auto; }
    .about-grid{ grid-template-columns:1fr; }
    .cert-grid{ grid-template-columns:1fr 1fr; }
    .skills-grid{ grid-template-columns:1fr; }
    .contact-card{ grid-template-columns:1fr; padding:36px 26px; }
