  }
  .btn-primary{ background:var(--ink); color:var(--paper-raise); }
  .btn-primary:hover{ background:var(--pulse); transform:translateY(-1px); }
  .btn-ghost{ border-color:var(--ink); color:var(--ink); }
  .btn-ghost:hover{ border-color:var(--pulse); color:var(--pulse); transform:translateY(-1px); }
 
  /* monogram / vitals card */
  .id-card{
    background:var(--paper-raise);
    border:1px solid var(--line);
    border-radius:8px;
    padding:28px;
    position:relative;
  }
  .id-card .avatar{
    width:100%;
